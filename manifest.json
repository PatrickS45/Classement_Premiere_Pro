{
  "id": "com.patricksanchez.binkeeper",
  "name": "BinKeeper",
  "version": "0.1.0",
  "main": "src/index.html",
  "manifestVersion": 6,
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "binkeeper.panel",
      "label": { "default": "BinKeeper" },
      "minimumSize": { "width": 320, "height": 400 },
      "preferredDockedSize": { "width": 360, "height": 600 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "allowCodeGenerationFromStrings": false
  },
  "icons": []
}
